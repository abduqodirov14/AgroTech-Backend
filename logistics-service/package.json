{
  "name": "agrohub-logistics-service",
  "version": "2.0.0",
  "description": "AgroHub Logistics — shipments, GPS, cold chain, fleet",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:push": "prisma db push",
    "seed": "tsx -e \"import { seedDemoData } from './src/services/seedService'; seedDemoData(true).then(console.log)\""
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "node-telegram-bot-api": "^0.67.0",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.1",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "@types/uuid": "^10.0.0",
    "prisma": "6.19.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0"
  }
}
