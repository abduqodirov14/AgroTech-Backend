generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VehicleType {
  TRUCK_10T
  TRUCK_20T
  REFRIGERATED
  VAN
}

enum VehicleStatus {
  AVAILABLE
  ON_ROUTE
  MAINTENANCE
  OFFLINE
}

model Vehicle {
  id               String        @id @default(cuid())
  plateNumber      String        @unique @map("plate_number")
  name             String?
  type             VehicleType
  capacityTons     Float         @map("capacity_tons")
  hasRefrigeration Boolean       @default(false) @map("has_refrigeration")
  status           VehicleStatus @default(AVAILABLE)
  fuelPercent      Int           @default(100) @map("fuel_percent")
  currentLat       Float?        @map("current_lat")
  currentLng       Float?        @map("current_lng")
  currentLocation  String?       @map("current_location")

  driverId  String? @unique
  driver    Driver? @relation(fields: [driverId], references: [id])
  shipments Shipment[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("vehicles")
}

model Driver {
  id         String  @id @default(cuid())
  fullName   String  @map("full_name")
  phone      String  @unique
  telegramId BigInt? @unique @map("telegram_id")
  isVerified Boolean @default(false) @map("is_verified")
  isActive   Boolean @default(true) @map("is_active")
  status    String @default("offline") @map("status")
  secureToken   String? @unique @map("secure_token")
  lastStatusUpdate DateTime? @map("last_status_update")
  licenseImage   String? @map("license_image")
  vehicleImage   String? @map("vehicle_image")

  vehicle   Vehicle?
  shipments Shipment[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("drivers")
}

enum ShipmentStatus {
  PENDING_DRIVER
  DRIVER_ASSIGNED
  EN_ROUTE_TO_PICKUP
  LOADING
  IN_TRANSIT
  ARRIVED
  DELIVERED
  COMPLETED
  CANCELLED
  COLD_CHAIN_ALERT
}

model Shipment {
  id              String         @id @default(cuid())
  trackId         String         @unique @map("track_id")
  orderId         String?        @unique @map("order_id")
  driverId        String?
  driver          Driver?        @relation(fields: [driverId], references: [id])
  vehicleId       String?
  vehicle         Vehicle?       @relation(fields: [vehicleId], references: [id])

  originLat       Float          @map("origin_lat")
  originLng       Float          @map("origin_lng")
  originAddress   String         @map("origin_address")
  destLat         Float          @map("dest_lat")
  destLng         Float          @map("dest_lng")
  destAddress     String         @map("dest_address")

  cargoType       String         @map("cargo_type")
  weightTons      Float          @map("weight_tons")
  freightCost     Float          @map("freight_cost")
  currency        String         @default("USD")

  status          ShipmentStatus @default(PENDING_DRIVER)
  tempCelsius     Float?         @map("temp_celsius")
  tempMaxAllowed  Float          @default(5) @map("temp_max_allowed")
  progressPercent Int            @default(0) @map("progress_percent")
  distanceKm      Float?         @map("distance_km")
  etaAt           DateTime?      @map("eta_at")

  trackingPoints ShipmentTracking[]
  documents      ShipmentDocument[]

  startedAt   DateTime? @map("started_at")
  deliveredAt DateTime? @map("delivered_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@index([status])
  @@index([trackId])
  @@map("shipments")
}

model ShipmentTracking {
  id          String   @id @default(cuid())
  shipmentId  String
  shipment    Shipment @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  lat         Float
  lng         Float
  tempCelsius Float?   @map("temp_celsius")
  recordedAt  DateTime @default(now()) @map("recorded_at")

  @@index([shipmentId, recordedAt])
  @@map("shipment_tracking")
}

enum DocumentType {
  WAYBILL
  CUSTOMS
  PHYTOSANITARY
  DELIVERY_PROOF
  INSURANCE
}

model DriverTrackerToken {
  id         String    @id @default(cuid())
  token      String    @unique
  trackId    String    @map("track_id")
  driverId   String    @map("driver_id")
  assignedAt DateTime  @default(now()) @map("assigned_at")
  consumedAt DateTime? @map("consumed_at")

  @@index([trackId])
  @@index([driverId])
  @@map("driver_tracker_tokens")
}

model ShipmentDocument {
  id         String       @id @default(cuid())
  shipmentId String
  shipment   Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)
  type       DocumentType
  fileUrl    String?      @map("file_url")
  metadata   Json?

  createdAt DateTime @default(now()) @map("created_at")

  @@map("shipment_documents")
}

model Warehouse {
  id          String  @id @default(cuid())
  name        String
  region      String
  latitude    Float
  longitude   Float
  capacityPct Float   @map("capacity_pct")
  stockValue  Float   @map("stock_value")
  currency    String  @default("USD")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([region])
  @@map("warehouses")
}

model Route {
  id                String @id @default(cuid())
  origin            String
  destination       String
  shipmentCount     Int    @default(0) @map("shipment_count")
  avgTravelHours    Float  @map("avg_travel_hours")
  onTimePercent     Float  @map("on_time_percent")
  distanceKm        Float  @map("distance_km")

  @@unique([origin, destination])
  @@map("routes")
}

model LogisticsCostSnapshot {
  id        String   @id @default(cuid())
  period    String
  total     Float
  fuel      Float
  transport Float
  warehouse Float
  other     Float
  currency  String   @default("USD")

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([period])
  @@map("logistics_cost_snapshots")
}

// =========================================================
// 6. FERMER HAMYONI (Wallet & Payments)
// =========================================================

enum TransactionType {
  DEPOSIT
  WITHDRAW
  REFUND
}

enum PaymentGateway {
  CLICK
  PAYME
  UZUM_BANK
  BANK_TRANSFER
  SYSTEM
}

enum TransactionStatus {
  PENDING
  SUCCESS
  FAILED
}

model FarmerWallet {
  id           String              @id @default(uuid())
  farmerId     String              @unique
  balance      Float               @default(0.0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions FarmerTransaction[]
}

model FarmerTransaction {
  id          String            @id @default(uuid())
  walletId    String
  wallet      FarmerWallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  shipmentId  String?
  amount      Float
  type        TransactionType
  gateway     PaymentGateway
  status      TransactionStatus @default(PENDING)
  description String?
  createdAt   DateTime          @default(now())

  @@index([walletId, createdAt])
}

model DriverWallet {
  id           String              @id @default(uuid())
  driverId     String              @unique
  balance      Float               @default(0.0)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  transactions DriverTransaction[]
}

model DriverTransaction {
  id          String            @id @default(uuid())
  walletId    String
  wallet      DriverWallet      @relation(fields: [walletId], references: [id], onDelete: Cascade)
  shipmentId  String?
  amount      Float
  type        TransactionType
  gateway     PaymentGateway
  status      TransactionStatus @default(PENDING)
  description String?
  createdAt   DateTime          @default(now())

  @@index([walletId, createdAt])
}
