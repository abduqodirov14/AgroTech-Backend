#!/bin/sh
basedir=$(dirname "$(echo "$0" | sed -e 's,\\,/,g')")

case `uname` in
    *CYGWIN*|*MINGW*|*MSYS*)
        if command -v cygpath > /dev/null 2>&1; then
            basedir=`cygpath -w "$basedir"`
        fi
    ;;
esac

if [ -z "$NODE_PATH" ]; then
  export NODE_PATH="/mnt/d/my start Up/Agrotech/backend/simulator/node_modules/.pnpm/mqtt@5.15.1/node_modules/mqtt/node_modules:/mnt/d/my start Up/Agrotech/backend/simulator/node_modules/.pnpm/mqtt@5.15.1/node_modules:/mnt/d/my start Up/Agrotech/backend/simulator/node_modules/.pnpm/node_modules"
else
  export NODE_PATH="/mnt/d/my start Up/Agrotech/backend/simulator/node_modules/.pnpm/mqtt@5.15.1/node_modules/mqtt/node_modules:/mnt/d/my start Up/Agrotech/backend/simulator/node_modules/.pnpm/mqtt@5.15.1/node_modules:/mnt/d/my start Up/Agrotech/backend/simulator/node_modules/.pnpm/node_modules:$NODE_PATH"
fi
if [ -x "$basedir/node" ]; then
  exec "$basedir/node"  "$basedir/../mqtt/build/bin/pub.js" "$@"
else
  exec node  "$basedir/../mqtt/build/bin/pub.js" "$@"
fi
