    "winston": "^3.11.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/mqtt": "^2.1.4",
    "@types/node": "^20.11.0",
    "prisma": "^6.19.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
