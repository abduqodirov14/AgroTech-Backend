{
  "name": "@agrohub/analytics-service",
  "version": "1.0.0",
  "description": "AgroHub Analytics Service — crop yields, sales, customers, stock level KPIs, smart recommendations",
  "main": "dist/server.js",
  "scripts": {
    "dev": "npx tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "seed": "npx tsx src/services/analyticsSeedService.ts",
    "prisma:generate": "npx prisma generate --schema=../shared/prisma/schema.prisma",
    "prisma:push": "npx prisma db push --schema=../shared/prisma/schema.prisma",
    "prisma:studio": "npx prisma studio --schema=../shared/prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "prisma": "^6.19.3",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3"
  }
}
