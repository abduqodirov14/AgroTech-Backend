generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// AUTH / USER
// ============================================

enum UserRole {
  FARMER
  BUYER
  DRIVER
  LOGISTICS_ADMIN
  ADMIN
}

model User {
  id         String    @id @default(cuid())
  phone      String    @unique
  telegramId BigInt?   @unique @map("telegram_id")
  fullName   String    @map("full_name")
  username   String?
  role       UserRole  @default(FARMER)
  lastLogin  DateTime? @map("last_login")

  zones       Zone[]
  notifications Notification[]
  deviceOwnerships DeviceOwnership[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("users")
}

model AuthSession {
  id         String   @id @default(uuid())
  phone      String
  telegramId BigInt?  @map("telegram_id")
  code       String
  expiresAt  DateTime @map("expires_at")
  isUsed     Boolean  @default(false) @map("is_used")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([phone, code])
  @@index([expiresAt])
  @@map("auth_sessions")
}

// ============================================
// FARM / ZONE / DEVICE
// ============================================

model Zone {
  id        String @id @default(cuid())
  name      String
  latitude  Float
  longitude Float
  userId    String
  user      User   @relation(fields: [userId], references: [id])

  devices   Device[]
  events    IrrigationEvent[]
  forecasts WeatherForecast[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId])
  @@map("zones")
}

model Device {
  id         String       @id @default(cuid())
  macAddress String       @unique @map("mac_address")
  macHash    String       @unique @map("mac_hash")
  name       String?
  secretKey  String       @map("secret_key")
  status     DeviceStatus @default(OFFLINE)
  lastSeen   DateTime?    @map("last_seen")

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  readings SensorReading[]
  events   IrrigationEvent[]

  ownerships DeviceOwnership[]

  createdAt DateTime @default(now()) @map("created_at")

  @@map("devices")
}

model DeviceOwnership {
  id       String  @id @default(cuid())
  deviceId String
  device   Device  @relation(fields: [deviceId], references: [id], onDelete: Cascade)
  userId   String
  user     User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  isOwner  Boolean @default(true) @map("is_owner")

  @@unique([deviceId, userId])
  @@index([userId])
  @@map("device_ownerships")
}

// ============================================
// SENSOR DATA
// ============================================

model SensorReading {
  id String @id @default(cuid())

  deviceId String
  device   Device @relation(fields: [deviceId], references: [id])

  moisture       Float?
  temperature    Float?
  ph             Float?
  ec             Float?
  npk            Float?
  battery        Float?
  signalStrength Int?   @map("signal_strength")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([deviceId])
  @@index([createdAt])
  @@map("sensor_readings")
}

// ============================================
// IRRIGATION
// ============================================

model IrrigationEvent {
  id String @id @default(cuid())

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  deviceId String?
  device   Device? @relation(fields: [deviceId], references: [id])

  startedAt DateTime  @map("started_at")
  endedAt   DateTime? @map("ended_at")

  durationSec Int? @map("duration_sec")

  status IrrigationStatus
  source IrrigationSource

  createdAt DateTime @default(now()) @map("created_at")

  @@map("irrigation_events")
}

// ============================================
// WEATHER
// ============================================

model WeatherForecast {
  id String @id @default(cuid())

  zoneId String
  zone   Zone   @relation(fields: [zoneId], references: [id])

  temperature   Float
  humidity      Float
  precipitation Float
  windSpeed     Float    @map("wind_speed")
  et0           Float
  forecastDate  DateTime @map("forecast_date")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([zoneId, forecastDate])
  @@map("weather_forecasts")
}

// ============================================
// NOTIFICATIONS
// ============================================

model Notification {
  id String @id @default(cuid())

  userId String
  user   User   @relation(fields: [userId], references: [id])

  type    NotificationType
  title   String
  message String
  isRead  Boolean          @default(false) @map("is_read")

  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, isRead])
  @@index([createdAt])
  @@map("notifications")
}

// ============================================
// FUTURE FEATURE — NOT FOR MVP
// ============================================

// IrrigationSchedule will be added in post-MVP phase.
// Do not create, query, or reference this model in MVP code.

// ============================================
// ENUMS
// ============================================

enum NotificationType {
  ALERT
  IRRIGATION
  WEATHER
  SYSTEM
}

enum DeviceStatus {
  ONLINE
  OFFLINE
}

enum IrrigationStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum IrrigationSource {
  MANUAL
  AI
  SCHEDULE
}
